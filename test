<!DOCTYPE html>
<html lang="el">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Chef's House Menu</title>

<style>
body{font-family:Arial;margin:0;background:#fff;color:#000}
h2{border-bottom:2px solid #ff7a00;padding-bottom:5px;margin-top:25px}
.item{display:flex;justify-content:space-between;padding:6px 0;border-bottom:1px solid #ccc}
.header{display:flex;justify-content:space-between;padding:10px;background:#ff7a00;color:white}
.logo{height:60px}
.container{padding:15px}
</style>

</head>

<body>

<header class="header">
  <img src="logo.png" class="logo">
  <a href="tel:2534024382" style="color:white;text-decoration:none;">📞</a>
</header>

<div class="container">

<h1>CHEF'S HOUSE</h1>
<h2>Μενού / Menu</h2>

<div id="menu"></div>

</div>

<!-- 🔥 FIREBASE FULL DYNAMIC -->
<script type="module">
import { initializeApp } from "https://www.gstatic.com/firebasejs/10.12.0/firebase-app.js";
import { getFirestore, collection, getDocs } from "https://www.gstatic.com/firebasejs/10.12.0/firebase-firestore.js";

const firebaseConfig = {
  apiKey: "AIzaSyCDJ2eFajFUldg7t3L458M6ssON2RYqwMo",
  authDomain: "menu-admin-panel-2ad76.firebaseapp.com",
  projectId: "menu-admin-panel-2ad76",
  storageBucket: "menu-admin-panel-2ad76.firebasestorage.app",
  messagingSenderId: "315806998737",
  appId: "1:315806998737:web:cf58cfb2deb1c493a1e5f0"
};

const app = initializeApp(firebaseConfig);
const db = getFirestore(app);

const menuDiv = document.getElementById("menu");

async function loadMenu(){
  const snap = await getDocs(collection(db, "menu"));

  const categories = {};

  snap.forEach(doc=>{
    const item = doc.data();

    if(!categories[item.category]){
      categories[item.category] = [];
    }

    categories[item.category].push(item);
  });

  for(let cat in categories){
    menuDiv.innerHTML += `<h2>${cat}</h2>`;

    categories[cat].forEach(p=>{
      menuDiv.innerHTML += `
        <div class="item">
          <span>${p.name}</span>
          <span>${p.price}€</span>
        </div>
      `;
    });
  }
}

loadMenu();
</script>

</body>
</html>
